{
  "clauses": [
    "core#presentation-pop",
    "core#authz-discovery"
  ],
  "exchanges": [
    {
      "expected": {
        "headers": {
          "WWW-Authenticate": {
            "excludesScheme": "Bearer"
          }
        },
        "status": 401
      },
      "request": {
        "agent": null,
        "method": "GET",
        "target": "https://storage.example/alice/notes/a.txt"
      }
    },
    {
      "expected": {
        "body": {
          "jsonContains": {
            "dpop_bound_access_tokens_required": true
          },
          "jsonHasMembers": [
            "pop_session"
          ]
        },
        "status": 200
      },
      "request": {
        "agent": null,
        "method": "GET",
        "target": "${response[0].authParam(resource_metadata)}"
      }
    }
  ],
  "id": "dpop-sk/pop-required-covers-dpop-sk",
  "input": {
    "state": {
      "issuerJwks": {
        "https://as.example": "keyring/as.jwks.json"
      },
      "now": "2026-07-01T12:00:00Z",
      "popProfiles": [
        "DPoP",
        "DPoP-SK"
      ],
      "popRequiredRealms": [
        "https://storage.example/alice/"
      ],
