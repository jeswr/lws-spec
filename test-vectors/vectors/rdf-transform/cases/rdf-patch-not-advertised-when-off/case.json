{
  "clauses": [
    "rdf#rdf-patch",
    "core#http-update"
  ],
  "exchanges": [
    {
      "expected": {
        "headers": {
          "Accept-Patch": {
            "excludesToken": "application/sparql-update"
          }
        },
        "status": 200
      },
      "request": {
        "method": "GET",
        "target": "https://storage.example/alice/notes/card.ttl"
      }
    },
    {
      "expected": {
        "status": 415
      },
      "request": {
        "body": "INSERT DATA { <https://storage.example/alice/notes/card.ttl#me> <http://schema.org/name> \"patched\" }",
        "headers": {
          "Content-Type": "application/sparql-update",
          "If-Match": "${response[0].header.ETag}"
        },
        "method": "PATCH",
        "target": "https://storage.example/alice/notes/card.ttl"
      }
    }
  ],
  "expected": {
    "stateAfter": {
      "bytesUnchanged": [
        "https://storage.example/alice/notes/card.ttl"
      ]
    }
  },
  "id": "rdf-transform/rdf-patch-not-advertised-when-off",
  "input": {
    "state": {
      "capabilities": [],
      "conformsTo": [
        "https://w3id.org/jeswr/lws/protocol/core/1.0"
      ],
      "resources": {
        "https://storage.example/alice/": {
          "type": "Container"
        },
        "https://storage.example/alice/notes/": {
          "type": "Container"
        },
        "https://storage.example/alice/notes/card.ttl": {
          "content": "@prefix schema: <http://schema.org/> .\n\n# stored formatting and this comment are part of the authoritative bytes\n<https://storage.example/alice/notes/card.ttl#me>\n    a             schema:Person ;\n    schema:name   \"Alice\" ;\n    schema:knows  <https://id.example/bob> .\n",
          "mediaType": "text/turtle",
          "type": "DataResource"
        }
      },
      "storageRoot": "https://storage.example/alice/"
    }
  },
  "level": "MUST",
  "operation": "http-exchange",
  "source": "lws-spec@f2e081d rdf#rdf-patch (spec-derived; no reference implementation yet)",
  "spec": "https://w3id.org/jeswr/lws/transform/rdf-1",
  "title": "RDF patch formats MUST NOT be advertised (Accept-Patch) for a media type the profile is not on for, and such a PATCH is rejected"
