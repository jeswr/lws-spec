{
  "clauses": [
    "rdf#authoritative-bytes"
  ],
  "exchanges": [
    {
      "expected": {
        "headers": {
          "ETag": {
            "present": true
          },
          "Vary": {
            "includesToken": "Accept"
          }
        },
        "status": 200
      },
      "request": {
        "headers": {
          "Accept": "text/turtle"
        },
        "method": "GET",
        "target": "https://storage.example/alice/notes/card.ttl"
      }
    },
    {
      "expected": {
        "headers": {
          "Content-Type": {
            "mediaType": "application/ld+json"
          },
          "ETag": {
            "present": true
          },
          "Vary": {
            "includesToken": "Accept"
          }
        },
        "status": 200
      },
      "request": {
        "headers": {
          "Accept": "application/ld+json"
        },
        "method": "GET",
        "target": "https://storage.example/alice/notes/card.ttl"
      }
    }
  ],
  "expected": {
    "asserts": [
      {
        "kind": "differ",
        "refs": [
          "response[0].header.ETag",
          "response[1].header.ETag"
        ]
      }
    ]
  },
  "id": "rdf-transform/per-representation-etags-differ",
  "input": {
    "state": {
      "capabilities": [
        {
          "profile": "https://w3id.org/jeswr/lws/transform/rdf-1",
          "source": "text/turtle",
          "target": [
            "application/ld+json",
            "application/n-triples"
          ],
          "type": "ContentNegotiation"
        },
        {
          "profile": "https://w3id.org/jeswr/lws/transform/rdf-1",
          "source": "application/ld+json",
          "target": [
            "text/turtle",
            "application/n-triples"
          ],
          "type": "ContentNegotiation"
        }
      ],
      "conformsTo": [
        "https://w3id.org/jeswr/lws/protocol/core/1.0",
        "https://w3id.org/jeswr/lws/transform/rdf-1"
      ],
      "resources": {
        "https://storage.example/alice/": {
          "type": "Container"
        },
        "https://storage.example/alice/notes/": {
          "type": "Container"
        },
        "https://storage.example/alice/notes/card.ttl": {
          "content": "@prefix schema: <http://schema.org/> .\n\n# stored formatting and this comment are part of the authoritative bytes\n<https://storage.example/alice/notes/card.ttl#me>\n    a             schema:Person ;\n    schema:name   \"Alice\" ;\n    schema:knows  <https://id.example/bob> .\n",
          "mediaType": "text/turtle",
          "type": "DataResource"
        }
      },
      "storageRoot": "https://storage.example/alice/"
    }
  },
  "level": "MUST",
  "operation": "http-exchange",
  "source": "lws-spec@f2e081d rdf#authoritative-bytes (spec-derived; no reference implementation yet)",
  "spec": "https://w3id.org/jeswr/lws/transform/rdf-1",
  "title": "the Turtle and JSON-LD representations of one resource state carry DIFFERENT ETags, and responses vary by Accept"
}
