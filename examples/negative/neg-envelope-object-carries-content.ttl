# AUTHORED-BY Claude Fable 5
# NEGATIVE: violates JLWSC-ENV-1 (#notification-envelope) — the object must carry
# the affected resource's id and type ONLY; this one smuggles resource content
# (as:content + as:mediaType). Mirrors
# test-vectors/vectors/notifications/cases/envelope-must-not-carry-content.
@prefix jlws: <https://w3id.org/jeswr/lws#> .
@prefix as:   <https://www.w3.org/ns/activitystreams#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

<urn:uuid:5e6d1f2a-1111-4e4e-9d9d-000000000003> a jlws:Notification , as:Update ;
    as:published "2026-07-01T12:00:00Z"^^xsd:dateTime ;
    as:object <https://storage.example/alice/notes/a.txt> .

<https://storage.example/alice/notes/a.txt> a jlws:DataResource ;
    as:mediaType "text/plain" ;
    as:content "milk, eggs, bread" .
